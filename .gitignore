# Local TLS artefact directories
# All generated lab outputs (keys, CSRs, certs, CA serial, and the CSR/ext config files produced from templates)
# live inside these two directories, so we ignore their contents wholesale and keep the directories themselves
# in version control via .gitkeep placeholders.
server-tls-items/*
!server-tls-items/.gitkeep
root-ca-tls-items/*
!root-ca-tls-items/.gitkeep

# Visual Studio Code — multi-root workspace definitions
*.code-workspace

# MacOS specific files
.DS_Store
